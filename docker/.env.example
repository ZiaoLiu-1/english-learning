# Copy to docker/.env and fill real values. docker/.env is gitignored.
# AUTH_SECRET signs session cookies — must be >=16 chars, keep it secret.
AUTH_SECRET=change-me-to-a-long-random-string
SEED_ADMIN_NAME=gary
SEED_LEARNER_NAME=learner
SEED_ADMIN_PASSWORD=change-me
SEED_LEARNER_PASSWORD=change-me
# NEXT_BASE_PATH is baked at build time; default /english. Override only if the
# public path changes.
NEXT_BASE_PATH=/english
