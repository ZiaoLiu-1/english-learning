      "payload": {
        "question": "现在进行时用来说什么？",
        "options": [
          "经常做、习惯性的事",
          "此刻正在进行的动作",
          "过去发生、已经结束的事"
        ]
      },
      "answer": {
        "index": 1
      },
      "explain_zh": "现在进行时说的是说话这一刻正在做的动作；经常/习惯的事用一般现在时，过去结束的事用一般过去时。"
    },
    {
      "uid": "L09-mcq-02",
      "type": "mcq",
      "difficulty": 1,
      "payload": {
        "question": "现在进行时是怎么构成的？",
        "options": [
          "be 动词 + 动词-ing",
